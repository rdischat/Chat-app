{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "The user's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The user's last name."
        },
        "userId": {
          "type": "string",
          "description": "Unique identifier chosen by the user."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "avatar": {
          "type": "string",
          "description": "Base64 encoded profile picture or URL."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "bio": {
          "type": "string",
          "description": "A short biography about the user."
        },
        "location": {
          "type": "string",
          "description": "The user's location."
        },
        "website": {
          "type": "string",
          "description": "The user's personal website URL."
        },
        "achievements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "icon": { "type": "string" },
              "unlockedAt": { "type": "string", "format": "date-time" }
            }
          },
          "description": "List of achievements earned by the user."
        },
        "activity": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          },
          "description": "Recent activity log for the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["firstName", "lastName", "userId", "phone", "email", "createdAt"]
    },
    "FriendRequest": {
      "title": "Friend Request",
      "description": "A request to become friends between two users.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "status", "createdAt"]
    },
    "Friend": {
      "title": "Friend",
      "description": "A connection between two users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "addedAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two or more users.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user UIDs participating in the chat."
        },
        "lastMessage": {
          "type": "string",
          "description": "The text of the most recent message."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat was last updated."
        }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "senderId": {
          "type": "string",
          "description": "The UID of the user who sent the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["text", "senderId", "createdAt"]
    },
    "Community": {
      "title": "Community",
      "description": "A group or community created by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "avatar": { "type": "string" },
        "memberCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorId", "createdAt"]
    },
    "CommunityMember": {
      "title": "Community Member",
      "description": "A user who is a member of a community.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "joinedAt"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "A post shared within a community.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" }
      },
      "required": ["text", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profile documents, keyed by their Auth UID."
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": "Friend",
      "description": "Subcollection of friends for a specific user."
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Global collection of friend requests."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of chat documents."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Subcollection of messages for a specific chat."
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Collection of community documents."
    },
    "/communities/{communityId}/members/{memberId}": {
      "schema": "CommunityMember",
      "description": "Subcollection of members for a specific community."
    },
    "/communities/{communityId}/posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Subcollection of posts within a community."
    }
  }
}
